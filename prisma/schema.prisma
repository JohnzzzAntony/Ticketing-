generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEPARTMENT_MANAGER
  AGENT
  EMPLOYEE
}

enum TicketStatus {
  NEW
  OPEN
  PENDING_CUSTOMER
  PENDING_INTERNAL
  PENDING_APPROVAL
  ESCALATED
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  TICKET_CREATED
  TICKET_ASSIGNED
  STATUS_UPDATED
  NEW_REPLY
  SLA_WARNING
  SLA_BREACHED
  APPROVAL_REQUESTED
  APPROVAL_ACTIONED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  NOT_REQUIRED
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String
  passwordHash  String
  role          Role         @default(EMPLOYEE)
  
  // A user can belong to one primary department, but can be an agent/manager for multiple
  departmentId  String?
  department    Department?  @relation("UserDepartment", fields: [departmentId], references: [id])
  
  // For Agents and Managers: Departments they can manage/work in
  managedDepartments Department[] @relation("DepartmentManagers")
  assignedDepartments Department[] @relation("DepartmentAgents")

  avatar        String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  createdTickets  Ticket[]     @relation("TicketCreator")
  assignedTickets Ticket[]     @relation("TicketAssignee")
  replies         Reply[]
  internalNotes   InternalNote[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  activityLogs    ActivityLog[]
  approvals       ApprovalRequest[]

  @@map("users")
  @@index([email])
  @@index([role])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  code        String   @unique // e.g., 'FIN', 'IT', 'HR'
  
  // Configurations
  slaConfig   DepartmentSLAConfig?
  routingRules String? // JSON string for keywords/auto-routing
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]       @relation("UserDepartment")
  managers    User[]       @relation("DepartmentManagers")
  agents      User[]       @relation("DepartmentAgents")
  categories  Category[]
  tickets     Ticket[]
  customFields DepartmentCustomField[]

  @@map("departments")
}

model Category {
  id           String      @id @default(cuid())
  name         String
  description  String?
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  
  // SLA overrides for specific categories
  responseTimeHours   Int?
  resolutionTimeHours Int?
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tickets      Ticket[]
  slaConfigs   SLAConfig[]

  @@unique([name, departmentId])
  @@map("categories")
}

model DepartmentCustomField {
  id           String     @id @default(cuid())
  name         String
  label        String
  type         String     // 'text', 'number', 'select', 'date', 'boolean'
  isRequired   Boolean    @default(false)
  options      String?    // JSON string for select options
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("department_custom_fields")
}

model Ticket {
  id          String       @id @default(cuid())
  ticketId    String       @unique
  title       String
  description String
  
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id])
  
  priority    Priority     @default(MEDIUM)
  status      TicketStatus @default(OPEN)
  tags        String       @default("")
  
  // JSON field for department-specific data
  customData  String?      @default("{}")
  
  approvalStatus ApprovalStatus @default(NOT_REQUIRED)
  
  creatorId   String
  creator     User         @relation("TicketCreator", fields: [creatorId], references: [id])
  assigneeId  String?
  assignee    User?        @relation("TicketAssignee", fields: [assigneeId], references: [id])
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  replies       Reply[]
  internalNotes InternalNote[]
  attachments   Attachment[]
  notifications Notification[]
  sla           SLARecord?
  activityLogs  ActivityLog[]
  approvals     ApprovalRequest[]

  @@map("tickets")
  @@index([status])
  @@index([priority])
  @@index([ticketId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([createdAt])
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  ticketId    String
  ticket      Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  approverId  String
  approver    User           @relation(fields: [approverId], references: [id])
  status      ApprovalStatus @default(PENDING)
  comments    String?
  stepName    String?        // e.g., 'Finance Approval'
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([ticketId])
  @@index([approverId])
  @@index([status])
  @@map("approval_requests")
}

model Reply {
  id        String   @id @default(cuid())
  content   String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@map("replies")
}

model InternalNote {
  id        String   @id @default(cuid())
  content   String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@map("internal_notes")
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  fileType  String
  fileSize  Int
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("attachments")
}

model SLARecord {
  id               String   @id @default(cuid())
  ticketId         String   @unique
  ticket           Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  responseDeadline DateTime
  resolutionDeadline DateTime
  firstResponseAt  DateTime?
  resolvedAt       DateTime?
  isBreached       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("sla_records")
  @@index([isBreached])
}

model DepartmentSLAConfig {
  id                 String     @id @default(cuid())
  departmentId       String     @unique
  department         Department @relation(fields: [departmentId], references: [id])
  
  defaultResponseTimeHours   Int @default(8)
  defaultResolutionTimeHours Int @default(48)
  
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("department_sla_configs")
}

model SLAConfig {
  id                 String   @id @default(cuid())
  categoryId         String   @unique
  category           Category @relation(fields: [categoryId], references: [id])
  
  responseTimeHours  Int      @default(4)
  resolutionTimeHours Int     @default(24)
  priority           Priority @default(MEDIUM)
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("sla_configs")
}

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketId   String?
  ticket     Ticket?          @relation(fields: [ticketId], references: [id])
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("activity_logs")
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model KnowledgeBaseArticle {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("knowledge_base_articles")
}
